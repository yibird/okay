{
  "name": "@zhouchengfeng/okay",
  "version": "1.0.0",
  "description": "A utility library for TypeScript, Vue, and React.",
  "keywords": [
    "composables",
    "function",
    "function utils",
    "hooks",
    "javascript utils",
    "okay",
    "react",
    "typescript utils",
    "util",
    "utils",
    "vue"
  ],
  "homepage": "https://github.com/yibird/okay#readme",
  "bugs": {
    "url": "https://github.com/yibird/okay/issues"
  },
  "license": "MIT",
  "author": "zchengfeng <2684837849@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yibird/okay.git"
  },
  "funding": "https://github.com/sponsors/yibird",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./async": {
      "types": "./dist/async.d.mts",
      "import": "./dist/async.mjs",
      "default": "./dist/async.mjs"
    },
    "./coll": {
      "types": "./dist/coll.d.mts",
      "import": "./dist/coll.mjs",
      "default": "./dist/coll.mjs"
    },
    "./date": {
      "types": "./dist/date.d.mts",
      "import": "./dist/date.mjs",
      "default": "./dist/date.mjs"
    },
    "./file": {
      "types": "./dist/file.d.mts",
      "import": "./dist/file.mjs",
      "default": "./dist/file.mjs"
    },
    "./is": {
      "types": "./dist/is.d.mts",
      "import": "./dist/is.mjs",
      "default": "./dist/is.mjs"
    },
    "./number": {
      "types": "./dist/number.d.mts",
      "import": "./dist/number.mjs",
      "default": "./dist/number.mjs"
    },
    "./string": {
      "types": "./dist/string.d.mts",
      "import": "./dist/string.mjs",
      "default": "./dist/string.mjs"
    },
    "./vue": {
      "types": "./dist/vue.d.mts",
      "import": "./dist/vue.mjs",
      "default": "./dist/vue.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs",
      "default": "./dist/react.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 8888",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt --write . --ignore-path .oxfmtignore",
    "format:check": "oxfmt --check . --ignore-path .oxfmtignore",
    "lint": "oxlint",
    "lint:fix": "pnpm run lint --fix",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "release:changeset": "changeset",
    "release:version": "changeset version",
    "release": "changeset publish",
    "test": "pnpm run test:unit",
    "test:bench": "tsx scripts/bench.ts",
    "test:coverage": "vitest --run --coverage",
    "test:unit": "vitest --run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:unit && pnpm run build && pnpm run pack:check"
  },
  "dependencies": {
    "dayjs": "^1.11.21"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "commitizen": "^4.3.2",
    "conventional-changelog-atom": "^5.1.0",
    "cz-git": "^1.13.1",
    "happy-dom": "^20.10.6",
    "mitata": "^1.0.34",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue": "^3.5.38"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "vue": ">=3.3.0 <4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
