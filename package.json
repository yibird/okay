{
  "name": "okay",
  "version": "0.0.12",
  "private": true,
  "description": "A monorepo utility library for TypeScript, Vue, and React.",
  "homepage": "https://github.com/yibird/okay#readme",
  "bugs": {
    "url": "https://github.com/yibird/okay/issues"
  },
  "license": "MIT",
  "author": "zchengfeng <2684837849@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yibird/okay.git"
  },
  "funding": "https://github.com/sponsors/yibird",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm -r --stream build",
    "build:packages": "tsdown",
    "dev": "pnpm -r --parallel dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 8888",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt --write . --ignore-path .oxfmtignore",
    "format:check": "oxfmt --check . --ignore-path .oxfmtignore",
    "lint": "oxlint",
    "lint:fix": "pnpm run lint --fix",
    "pack:check": "pnpm --filter @zhouchengfeng/okay-core --filter @zhouchengfeng/okay-vue --filter @zhouchengfeng/okay-react --stream exec npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "release:changeset": "changeset",
    "release:version": "changeset version",
    "release": "changeset publish",
    "test": "pnpm run test:unit",
    "test:bench": "tsx scripts/bench.ts",
    "test:coverage": "vitest --run --coverage",
    "test:unit": "vitest --run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:unit && pnpm run build && pnpm run pack:check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "commitizen": "^4.3.1",
    "conventional-changelog-atom": "^5.1.0",
    "cz-git": "^1.13.1",
    "dayjs": "^1.11.21",
    "happy-dom": "^20.9.0",
    "mitata": "^1.0.34",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8",
    "vue": "^3.5.35"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "packageManager": "pnpm@10.11.0"
}
