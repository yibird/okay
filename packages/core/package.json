{
  "name": "@zhouchengfeng/okay-core",
  "version": "0.0.12",
  "description": "a utility function library",
  "keywords": [
    "function",
    "function utils",
    "javascript utils",
    "okay",
    "typescript utils",
    "util",
    "utils"
  ],
  "homepage": "https://github.com/yibird/okay#readme",
  "bugs": {
    "url": "https://github.com/yibird/okay/issues"
  },
  "license": "MIT",
  "author": "zchengfeng <2684837849@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yibird/okay.git"
  },
  "funding": "https://github.com/sponsors/yibird",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./async": {
      "types": "./dist/async.d.mts",
      "import": "./dist/async.mjs",
      "default": "./dist/async.mjs"
    },
    "./coll": {
      "types": "./dist/coll.d.mts",
      "import": "./dist/coll.mjs",
      "default": "./dist/coll.mjs"
    },
    "./date": {
      "types": "./dist/date.d.mts",
      "import": "./dist/date.mjs",
      "default": "./dist/date.mjs"
    },
    "./file": {
      "types": "./dist/file.d.mts",
      "import": "./dist/file.mjs",
      "default": "./dist/file.mjs"
    },
    "./is": {
      "types": "./dist/is.d.mts",
      "import": "./dist/is.mjs",
      "default": "./dist/is.mjs"
    },
    "./number": {
      "types": "./dist/number.d.mts",
      "import": "./dist/number.mjs",
      "default": "./dist/number.mjs"
    },
    "./string": {
      "types": "./dist/string.d.mts",
      "import": "./dist/string.mjs",
      "default": "./dist/string.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --filter @zhouchengfeng/okay-core",
    "dev": "tsdown --filter @zhouchengfeng/okay-core --watch",
    "test": "vitest --run src"
  },
  "dependencies": {
    "dayjs": "^1.11.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
